# EditorConfig helps maintain consistent coding styles across different editors
# https://editorconfig.org

root = true

# All files
[*]
charset = utf-8
end_of_line = lf
insert_final_newline = true
trim_trailing_whitespace = true

# TypeScript, JavaScript, JSX, TSX, JSON files
[*.{ts,tsx,js,jsx,json}]
indent_style = space
indent_size = 2

# Markdown files
[*.md]
indent_style = space
indent_size = 2
trim_trailing_whitespace = false

# SQL migration files
[*.sql]
indent_style = space
indent_size = 2

# YAML configuration files
[*.{yaml,yml}]
indent_style = space
indent_size = 2

# Makefiles - must use tabs
[Makefile]
indent_style = tab

# Binary lock file - preserve as-is
[bun.lockb]
insert_final_newline = false
trim_trailing_whitespace = false
charset = unset
