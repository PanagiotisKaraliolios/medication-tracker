{
  "expo": {
    "name": "MediTrack",
    "slug": "medication-tracker",
    "scheme": "medication-tracker",
    "version": "1.3.0",
    "orientation": "default",
    "icon": "./assets/icon.png",
    "userInterfaceStyle": "automatic",
    "splash": {
      "image": "./assets/splash-icon.png",
      "resizeMode": "contain",
      "backgroundColor": "#ffffff"
    },
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "com.anonymous.medicationtracker"
    },
    "android": {
      "adaptiveIcon": {
        "foregroundImage": "./assets/adaptive-icon.png",
        "backgroundColor": "#1FA2A6"
      },
      "predictiveBackGestureEnabled": false,
      "package": "com.anonymous.medicationtracker",
      "permissions": [
        "android.permission.REQUEST_IGNORE_BATTERY_OPTIMIZATIONS",
        "android.permission.SCHEDULE_EXACT_ALARM"
      ]
    },
    "web": {
      "favicon": "./assets/favicon.png"
    },
    "plugins": [
      "expo-router",
      [
        "expo-notifications",
        {
          "enableBackgroundRemoteNotifications": false,
          "android": {
            "useNextSchedulerImplementation": true
          }
        }
      ],
      "@react-native-google-signin/google-signin",
      [
        "react-native-google-mobile-ads",
        {
          "androidAppId": "ca-app-pub-2807646854687473~3597996742",
          "iosAppId": "ca-app-pub-xxxxxxxx~yyyyyyyy"
        }
      ],
      [
        "expo-build-properties",
        {
          "android": {
            "dependencies": [
              "com.google.ads.mediation:meta:6.20.0.0",
              "com.google.ads.mediation:unity:4.14.0.0"
            ]
          }
        }
      ],
      "expo-font"
    ],
    "extra": {
      "router": {},
      "eas": {
        "projectId": "f015c455-1e93-4fe0-8aab-b1cfde09d1cc"
      }
    },
    "owner": "karalioliospanagiotis"
  }
}
